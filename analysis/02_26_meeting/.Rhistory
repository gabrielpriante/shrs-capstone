)
library(tidyverse)
library(educationdata)
library(scales)
library(kableExtra)
# ═══════════════════════════════════════════════════════════════════════════
# Source the spigot file to load institution-level completions
# ─────────────────────────────────────────────────────────────────────────
# Option A: Source the purl'd R code (preferred — uses cached API data)
# Option B: If that fails, we re-define the crosswalk and pull fresh
# ═══════════════════════════════════════════════════════════════════════════
# --- EDIT THIS PATH to match where you saved the spigot file ---
SPIGOT_PATH <- "/Users/gpps/Documents/shrs-capstone/analysis/02_26_meeting/ipeds_01_completions_spigot.Rmd"
if (file.exists(SPIGOT_PATH)) {
source(knitr::purl(SPIGOT_PATH, output = tempfile(), quiet = TRUE))
cat("Sourced spigot file. institution_completions has",
nrow(institution_completions), "rows\n")
} else {
stop("Cannot find spigot file at: ", SPIGOT_PATH,
"\nUpdate SPIGOT_PATH to point to your ipeds_01 file.")
}

filter(pct > 0) |>
left_join(edu_labels, by = "category") |>
mutate(edu_level = factor(edu_level, levels = edu_labels$edu_level))
edu_dist |>
ggplot(aes(x = shrs_program, y = pct, fill = edu_level)) +
geom_col(width = 0.7) +
scale_fill_viridis_d(option = "D", direction = -1, name = "Education Level") +
labs(
title = "Education Level Distribution by SHRS Occupation",
subtitle = "Percent of workers at each education level (O*NET incumbent survey)",
x = NULL, y = "Percent of Workers (%)"
) +
theme_minimal(base_size = 13) +
theme(legend.position = "right")
edu_dist |>
select(Program = shrs_program, `Education Level` = edu_level,
`% of Workers` = pct) |>
mutate(`% of Workers` = round(`% of Workers`, 1)) |>
kable() |>
kable_styling(bootstrap_options = c("striped", "hover"), full_width = FALSE)
exp_labels <- tribble(
~category, ~experience,
1,  "None",
2,  "Up to 1 month",
3,  "1–3 months",
4,  "3–6 months",
5,  "6 months–1 year",
6,  "1–2 years",
7,  "2–4 years",
8,  "4–6 years",
9,  "6–10 years",
10, "Over 10 years",
11, "Missing"
)
exp_dist <- edu_raw |>
filter(element_id == "3.A.1", scale_id == "RW") |>
mutate(category = as.integer(category),
pct = as.numeric(data_value)) |>
filter(pct > 0, category != 11) |>
left_join(exp_labels, by = "category") |>
mutate(experience = factor(experience, levels = exp_labels$experience))
exp_dist |>
ggplot(aes(x = shrs_program, y = pct, fill = experience)) +
geom_col(width = 0.7) +
scale_fill_viridis_d(option = "C", direction = -1, name = "Experience") +
labs(
title = "Related Work Experience Distribution by SHRS Occupation",
subtitle = "Percent of workers reporting each level of prior experience (O*NET)",
x = NULL, y = "Percent of Workers (%)"
) +
theme_minimal(base_size = 13) +
theme(legend.position = "right")
ojt_labels <- tribble(
~category, ~training,
1, "None",
2, "1 day to 1 month",
3, "1–3 months",
4, "3–6 months",
5, "6 months–1 year",
6, "1–2 years",
7, "2–4 years",
8, "4–10 years",
9, "Over 10 years"
)
ojt_dist <- edu_raw |>
filter(element_id == "3.A.3", scale_id == "OJ") |>
mutate(category = as.integer(category),
pct = as.numeric(data_value)) |>
filter(pct > 0) |>
left_join(ojt_labels, by = "category") |>
mutate(training = factor(training, levels = ojt_labels$training))
if (nrow(ojt_dist) > 0) {
ojt_dist |>
ggplot(aes(x = shrs_program, y = pct, fill = training)) +
geom_col(width = 0.7) +
scale_fill_viridis_d(option = "B", direction = -1, name = "OJT Duration") +
labs(
title = "On-the-Job Training Requirements by SHRS Occupation",
subtitle = "O*NET incumbent survey",
x = NULL, y = "Percent of Workers (%)"
) +
theme_minimal(base_size = 13) +
theme(legend.position = "right")
}
# Dominant education level per program
dominant_edu <- edu_dist |>
group_by(shrs_program) |>
slice_max(pct, n = 1) |>
select(shrs_program, dominant_edu = edu_level, edu_pct = pct)
# Top skill cluster per program
top_cluster <- onet_clustered |>
group_by(shrs_program) |>
slice_max(avg_importance, n = 1) |>
select(shrs_program, top_cluster = cluster, cluster_importance = avg_importance)
# Top BLS skill per program
top_bls_skill <- bls_skills |>
group_by(shrs_program) |>
slice_max(percentile, n = 1) |>
select(shrs_program, top_bls_skill = skill, top_percentile = percentile)
# Average O*NET importance (overall skill intensity)
avg_intensity <- onet_skills |>
group_by(shrs_program) |>
summarise(avg_skill_importance = round(mean(importance, na.rm = TRUE), 2),
.groups = "drop")
# Combine
synthesis <- soc_crosswalk |>
select(shrs_program, shrs_dept) |>
left_join(dominant_edu, by = "shrs_program") |>
left_join(top_cluster, by = "shrs_program") |>
left_join(top_bls_skill, by = "shrs_program") |>
left_join(avg_intensity, by = "shrs_program")
synthesis |>
select(
Program            = shrs_program,
Dept               = shrs_dept,
`Primary Education`  = dominant_edu,
`% at that Level`    = edu_pct,
`Top Skill Cluster`  = top_cluster,
`Top BLS Skill`      = top_bls_skill,
`Skill Intensity`    = avg_skill_importance
) |>
kable(digits = 1) |>
kable_styling(bootstrap_options = c("striped", "hover"), full_width = FALSE)
# Use skill intensity vs education level as a 2D positioning
edu_numeric <- tribble(
~dominant_edu,                      ~edu_years,
"Less than HS",                     10,
"HS Diploma/GED",                   12,
"Post-secondary Certificate",       13,
"Some College",                     14,
"Associate's Degree",               14,
"Bachelor's Degree",                16,
"Post-baccalaureate Certificate",   17,
"Master's Degree",                  18,
"Post-master's Certificate",        19,
"First Professional Degree",        20,
"Doctoral Degree",                  21,
"Post-doctoral Training",           22
)
positioning <- synthesis |>
left_join(edu_numeric, by = "dominant_edu")
positioning |>
ggplot(aes(x = edu_years, y = avg_skill_importance,
color = shrs_program, label = shrs_program)) +
geom_point(size = 5) +
geom_text(vjust = -1.2, size = 4.5, fontface = "bold") +
scale_color_manual(values = program_colors) +
scale_x_continuous(
breaks = c(16, 18, 21),
labels = c("Bachelor's", "Master's", "Doctoral")
) +
labs(
title = "Program Positioning: Education Level vs Skill Intensity",
subtitle = "Where each SHRS program sits in terms of training investment and skill demands",
x = "Dominant Education Level", y = "Average Skill Importance (O*NET 1–5)"
) +
theme_minimal(base_size = 13) +
theme(legend.position = "none")
knitr::opts_chunk$set(
echo    = TRUE,
message = FALSE,
warning = FALSE,
fig.width = 10,
fig.height = 6
)
install.packages("educationdata")
knitr::opts_chunk$set(
echo    = TRUE,
message = FALSE,
warning = FALSE,
fig.width = 10,
fig.height = 6
)
# ── Core tidyverse ──
library(tidyverse)
# ── API access ──
# install.packages("educationdata")
# OR: devtools::install_github("UrbanInstitute/education-data-package-r")
library(educationdata)
# ── Display ──
library(scales)
library(kableExtra)
# ═══════════════════════════════════════════════════════════════════════════
# CIP ↔ SHRS Program ↔ SOC Crosswalk
# ─────────────────────────────────────────────────────────────────────────
# Notes:
#   - CIP codes here use the 2020 CIP taxonomy (current as of IPEDS 2020-21+)
#   - Some programs map to multiple CIPs (e.g., SLP has its own code + a
#     combined SLP/AuD code). We include both to capture all completions.
#   - `cip_6digit` is the integer form for the API (no dots)
#   - `cip_display` is the human-readable form (with dots)
# ═══════════════════════════════════════════════════════════════════════════
cip_crosswalk <- tribble(
~shrs_program, ~shrs_dept, ~soc_code,  ~cip_6digit, ~cip_display, ~cip_title,
# ── Communication Science & Disorders ──
"SLP",         "CSD",      "29-1127",  510203L,     "51.0203",    "Speech-Language Pathology/Pathologist",
"SLP",         "CSD",      "29-1127",  510204L,     "51.0204",    "Audiology/Audiologist and SLP (Combined)",
"AuD",         "CSD",      "29-1181",  510202L,     "51.0202",    "Audiology/Audiologist",
"AuD",         "CSD",      "29-1181",  510204L,     "51.0204",    "Audiology/Audiologist and SLP (Combined)",
# ── Sports Medicine & Nutrition ──
"DN",          "SMN",      "29-1031",  513101L,     "51.3101",    "Dietetics/Dietitian",
"DN",          "SMN",      "29-1031",  513104L,     "51.3104",    "Dietitian Assistant",
"AT",          "SMN",      "29-9091",  510913L,     "51.0913",    "Athletic Training/Trainer",
"SS",          "SMN",      "29-1128",  260908L,     "26.0908",    "Exercise Physiology and Kinesiology",
"SS",          "SMN",      "29-1128",  310505L,     "31.0505",    "Kinesiology and Exercise Science"
)
# Unique CIP codes to pull from the API
target_cips <- unique(cip_crosswalk$cip_6digit)
cat("Target CIP codes:", paste(target_cips, collapse = ", "), "\n")
cat("SHRS programs covered:", paste(unique(cip_crosswalk$shrs_program), collapse = ", "), "\n")
# ═══════════════════════════════════════════════════════════════════════════
# IPEDS Award Level Codes
# ─────────────────────────────────────────────────────────────────────────
# These are the standard IPEDS award level codes used in the completions
# survey. The Urban Institute API uses the same codes.
#
# We focus on levels 5 (Bachelor's), 7 (Master's), 17 (Doctor's -
# Professional Practice), and 18 (Doctor's - Research/Scholarship).
# Level 17 is the relevant doctoral for clinical programs like AuD, DPT.
# Level 18 captures PhD/research doctorates.
# ═══════════════════════════════════════════════════════════════════════════
award_level_labels <- tribble(
~award_level, ~award_label,          ~degree_group,
1L,           "< 1 year Certificate", "Certificate",
2L,           "1-2 year Certificate",  "Certificate",
3L,           "Associate's",           "Associate's",
4L,           "2-4 year Certificate",  "Certificate",
5L,           "Bachelor's",            "Bachelor's",
6L,           "Postbacc Certificate",  "Certificate",
7L,           "Master's",              "Master's",
8L,           "Post-Master's Cert",    "Certificate",
17L,          "Doctorate - Professional Practice", "Doctorate",
18L,          "Doctorate - Research",  "Doctorate",
19L,          "Doctorate - Other",     "Doctorate"
)
# The degree levels we care about for the spigot analysis
degree_levels <- c(5L, 7L, 17L, 18L, 19L)
degree_labels <- award_level_labels |> filter(award_level %in% degree_levels)
# Pennsylvania FIPS code for state-level filtering
PA_FIPS <- 42L
# Regional FIPS codes (PA + bordering states: OH, WV, MD, NY, NJ, DE, VA)
REGIONAL_FIPS <- c(
42L,  # Pennsylvania
39L,  # Ohio
54L,  # West Virginia
24L,  # Maryland
36L,  # New York
34L,  # New Jersey
10L,  # Delaware
51L   # Virginia
)
regional_fips_labels <- tribble(
~fips, ~state_abbr, ~state_name,
42L,   "PA", "Pennsylvania",
39L,   "OH", "Ohio",
54L,   "WV", "West Virginia",
24L,   "MD", "Maryland",
36L,   "NY", "New York",
34L,   "NJ", "New Jersey",
10L,   "DE", "Delaware",
51L,   "VA", "Virginia"
)
# ═══════════════════════════════════════════════════════════════════════════
# Pull completions data from the Urban Institute Education Data API
# ─────────────────────────────────────────────────────────────────────────
# Strategy:
#   - Pull one CIP code at a time (API is more reliable this way)
#   - Request years 2012-2022 (reliable range for 6-digit CIP data)
#   - Filter to degree-level awards only
#   - add_labels = TRUE maps integer codes to readable labels
#
# The API returns one row per institution × year × CIP × award level ×
# race × sex. We aggregate up from there.
# ═══════════════════════════════════════════════════════════════════════════
# Year range — Urban Institute typically has data through 2022
YEAR_START <- 2012L
YEAR_END   <- 2022L
pull_completions <- function(cip_code, years = YEAR_START:YEAR_END) {
message("Pulling CIP ", cip_code, " ...")
tryCatch({
df <- get_education_data(
level   = "college-university",
source  = "ipeds",
topic   = "completions-cip-6",
filters = list(
year          = years,
cipcode_6digit = cip_code
),
add_labels = TRUE
)
message("  Got ", nrow(df), " rows for CIP ", cip_code)
return(df)
}, error = function(e) {
message("  ERROR pulling CIP ", cip_code, ": ", e$message)
return(NULL)
})
}
# Pull all target CIPs
# NOTE: This may take several minutes depending on API speed.
#       Set cache=TRUE in the chunk header to avoid re-pulling on re-knit.
raw_completions_list <- map(target_cips, pull_completions)
knitr::opts_chunk$set(
echo    = TRUE,
message = FALSE,
warning = FALSE,
fig.width = 10,
fig.height = 6
)
